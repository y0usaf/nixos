# Black Metal (Marduk) - base16 scheme by metalelf0
# Dark, near-monochromatic palette with muted teal accents
{
  colors = {
    color0 = "#000000"; # base00 - background
    color1 = "#5f8787"; # base08 - teal (Marduk accent)
    color2 = "#a5aaa7"; # base0B - muted sage
    color3 = "#626b67"; # base0A - dark olive
    color4 = "#888888"; # base0D - mid gray
    color5 = "#999999"; # base0E - light gray
    color6 = "#aaaaaa"; # base0C - silver
    color7 = "#c1c1c1"; # base05 - foreground
    color8 = "#333333"; # base03 - dark gray
    color9 = "#5f8787"; # base08 - teal (bright)
    color10 = "#a5aaa7"; # base0B - muted sage (bright)
    color11 = "#626b67"; # base0A - dark olive (bright)
    color12 = "#888888"; # base0D - mid gray (bright)
    color13 = "#999999"; # base0E - light gray (bright)
    color14 = "#aaaaaa"; # base0C - silver (bright)
    color15 = "#c1c1c1"; # base07 - light foreground
  };
  special = {
    background = "#000000"; # base00 - pure black
    foreground = "#c1c1c1"; # base05 - light gray
    cursor = "#5f8787"; # base08 - teal accent
  };
}
